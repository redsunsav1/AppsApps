# === Telegram Bot ===
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-domain.amvera.io
APP_URL=https://your-domain.amvera.io

# === MAX Messenger ===
MAX_ENABLED=true
MAX_BOT_TOKEN=your_max_bot_token_here
MAX_BOT_USERNAME=id301904538307_bot
MAX_WEBHOOK_URL=https://your-domain.amvera.io
# Optional: 5-256 chars, A-Z/a-z/0-9/_/-
MAX_WEBHOOK_SECRET=your_max_webhook_secret
ADMIN_MAX_ID=your_max_user_id

# === PostgreSQL ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === CORS (comma-separated, optional) ===
ALLOWED_ORIGINS=https://your-domain.amvera.io,https://web.telegram.org

# === Email (optional, for notifications) ===
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=recipient@example.com

# === Server ===
PORT=8080
